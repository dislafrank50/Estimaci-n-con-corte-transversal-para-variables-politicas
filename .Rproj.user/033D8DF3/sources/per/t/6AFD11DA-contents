## 2. Construcción del data frame de análisis


```{r merge_datos}
# Unimos los CUATRO ficheros usando el código ISO3 como clave común

# Paso 1: GTED + V-Dem
df_temp1 <- left_join(gted_cs, vdem_cs, by = c("iso3_gted" = "iso3_vdem"))

# Paso 2: Añadimos PIB del Banco Mundial
df_temp2 <- left_join(df_temp1, bm_gdp_cs, by = c("iso3_gted" = "iso3_bm"))

# Paso 3: Añadimos Ideología y Populismo de V-Party
df_raw <- left_join(df_temp2, vparty_cs, by = c("iso3_gted" = "iso3_vparty"))

cat("Observaciones antes de limpiar:", nrow(df_raw), "\n")
```

```{r limpiar_datos}
# --------------------------------------------------------------------------
# Lista de los 38 países de la OCDE (Códigos ISO3)
# --------------------------------------------------------------------------
paises_ocde <- c(
  "AUS", "AUT", "BEL", "CAN", "CHL", "COL", "CRI", "CZE", "DNK", "EST", 
  "FIN", "FRA", "DEU", "GRC", "HUN", "ISL", "IRL", "ISR", "ITA", "JPN", 
  "KOR", "LVA", "LTU", "LUX", "MEX", "NLD", "NZL", "NOR", "POL", "PRT", 
  "SVK", "SVN", "ESP", "SWE", "CHE", "TUR", "GBR", "USA"
)

# --------------------------------------------------------------------------
# Limpieza, Filtro OCDE y transformaciones
# --------------------------------------------------------------------------
df <- df_raw %>%
  # 1. FILTRAMOS SOLO PAÍSES OCDE
  filter(iso3_gted %in% paises_ocde) %>%
  
  # 2. Limpieza de NAs solo en las variables críticas
  filter(!is.na(te_cit_gdp),
         !is.na(v2x_polyarchy),
         !is.na(gdp_const2015)) %>%
  filter(te_cit_gdp > 0)

# Transformaciones
df <- df %>%
  mutate(
    ln_te_cit    = log(te_cit_gdp),
    ln_gdp       = log(gdp_const2015),
    dem2         = v2x_polyarchy^2,
    etiqueta     = iso3_gted
  )

cat("Observaciones finales (solo OCDE en 2019):", nrow(df), "\n")
head(df)
```

