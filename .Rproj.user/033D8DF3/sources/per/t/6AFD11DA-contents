## 1.2 Datos del Banco Mundial — PIB per cápita (GDP constant 2015 US$)

```{r cargar_bm}
library(dplyr)
library(readr)

# 1. Definimos el año de análisis directamente a 2019
ANIO <- 2019

# Ruta del fichero
ruta_bm <- "C:/Users/New Frank/Documents/TFM/data/raw-data/Controles_05a34175-206f-4867-be52-acf057444306_Data.csv"

# Carga del CSV
bm_raw <- read_csv(ruta_bm, skip = 0, show_col_types = FALSE)

# Aseguramos que el año sea numérico para el filtro
anio_corte <- as.numeric(ANIO)

# Transformación de panel a corte transversal y limpieza del PIB
bm_gdp_cs <- bm_raw %>%
  # Filtramos para quedarnos con una única "foto" en el tiempo
  filter(Time == anio_corte) %>%
  select(
    pais_bm       = `Country Name`,
    iso3_bm       = `Country Code`,
    gdp_const2015 = `GDP (constant 2015 US$) [NY.GDP.MKTP.KD]`
  ) %>%
  mutate(gdp_const2015 = as.numeric(na_if(gdp_const2015, ".."))) %>%
  filter(!is.na(gdp_const2015))

head(bm_gdp_cs)
```

