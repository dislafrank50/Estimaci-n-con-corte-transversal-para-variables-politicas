## 1.4 Datos GTED — Gasto fiscal CIT (% del PIB)

```{r cargar_gted}
library(readxl)

# Ruta del fichero 
ruta_gted <- "C:/Users/New Frank/Documents/TFM/data/raw-data/GTED_FullDatabase_20251010.xlsx"

gted_provisions <- read_excel(ruta_gted, sheet = "TEProvisions")
gted_rf <- read_excel(ruta_gted, sheet = "RevenueForgone")

anio_corte <- as.numeric(ANIO)

cit_provisions <- gted_provisions %>%
  filter(grepl("Corporate Income Tax|CIT", `Tax type - Level 2`, ignore.case = TRUE)) %>%
  select(
    ProvisionID = `Provision ID`, 
    iso3_gted   = `Country Code`
  )

gted_cs <- gted_rf %>%
  filter(Year == anio_corte) %>%
  select(
    iso3_gted   = Country,
    ProvisionID = ProvisionID,
    anio_gted   = Year,
    te_cit_gdp  = `RF % of GDP` 
  ) %>%
  mutate(te_cit_gdp = as.numeric(te_cit_gdp)) %>%
  inner_join(cit_provisions, by = c("ProvisionID", "iso3_gted")) %>%
  group_by(iso3_gted, anio_gted) %>%
  summarise(te_cit_gdp = sum(te_cit_gdp, na.rm = TRUE), .groups = "drop")

head(gted_cs)
```

## 1.5 Datos V-Party — Ideología y Populismo

```{r cargar_vparty}
library(tidyr) # Necesario para la función fill()

# Lista CORREGIDA de variables de V-Party según el Codebook oficial
variables_ideologia_vparty <- c(
  "v2pariglef",        # Escala económica izquierda-derecha
  "v2pawelf",          # Apoyo al estado de bienestar
  "v2parelig",         # Principios religiosos
  "v2paimmig",         # Inmigración
  "v2palgbt",          # Igualdad social LGBT
  "v2pagender",        # Igualdad de género
  "v2xpa_popul",       # Índice de populismo
  "v2paanteli",        # Anti-elitismo
  "v2papeople",        # Pueblo-centrismo
  "v2xpa_antiplural",  # Índice de anti-pluralismo
  "v2paplur",          # Pluralismo político
  "v2paopresp",        # Demonización de oponentes
  "v2paminor",         # Derechos de minorías
  "v2paclient"         # Clientelismo
)

# RUTA: Asegúrate de que esta es la ruta correcta en tu PC
ruta_vparty <- "C:/Users/New Frank/Documents/TFM/data/raw-data/CPD_V-Party_CSV_v2/V-Dem-CPD-Party-V2.csv"

# Cargar V-Party
vparty_raw <- read_csv(ruta_vparty, show_col_types = FALSE)

# Procesamiento: Pasar de "Partido-Elección" a "País-Año (Partido Gobernante)"
vparty_cs <- vparty_raw %>%
  # 1. Filtramos hasta nuestro año de corte (2019)
  filter(year <= ANIO) %>%
  
  # 2. Nos quedamos solo con el partido con más escaños en el parlamento
  # CORRECCIÓN: Usamos 'v2paseatshare' que es el nombre correcto en V-Party
  group_by(country_text_id, year) %>%
  slice_max(order_by = v2paseatshare, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  
  # 3. Seleccionamos las variables clave
  select(
    iso3_vparty = country_text_id,
    year,
    party_name  = v2pashname, 
    any_of(variables_ideologia_vparty)
  ) %>%
  
  # 4. Completar los años sin elecciones
  complete(iso3_vparty, year = 1990:ANIO) %>%
  group_by(iso3_vparty) %>%
  arrange(year) %>%
  # CORRECCIÓN: Forma más robusta de arrastrar los valores hacia abajo (LOCF)
  fill(c(party_name, any_of(variables_ideologia_vparty)), .direction = "down") %>%
  ungroup() %>%
  
  # 5. Finalmente, filtramos solo la "foto" de 2019
  filter(year == ANIO)

head(vparty_cs)

```

