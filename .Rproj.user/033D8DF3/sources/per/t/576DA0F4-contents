```

```{r punto_inflexion_mod3}
# Si el Modelo 3 es el elegido: calcular el punto de inflexión
cat("=== Punto de inflexión — Modelo 3 (cuadrático) ===\n")
beta1_mod3 <- coef(mod3)["v2x_polyarchy"]
beta2_mod3 <- coef(mod3)["dem2"]
dem_star   <- -beta1_mod3 / (2 * beta2_mod3)

cat("β₁ =", round(beta1_mod3, 4), "\n")
cat("β₂ =", round(beta2_mod3, 4), "\n")
cat("dem* = -β₁ / (2·β₂) =", round(dem_star, 4), "\n")

if (beta2_mod3 < 0) {
  cat("Como β₂ < 0, la parábola es cóncava (U invertida):\n")
  cat("  El gasto CIT es MÁXIMO cuando v2x_polyarchy =", round(dem_star, 3), "\n")
  cat("  Por encima de ese nivel, mayor democracia → menor gasto tributario CIT.\n")
} else {
  cat("Como β₂ > 0, la parábola es convexa (U):\n")
  cat("  El gasto CIT es MÍNIMO cuando v2x_polyarchy =", round(dem_star, 3), "\n")
}
