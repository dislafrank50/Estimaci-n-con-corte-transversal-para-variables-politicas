# 2. Estimación de los modelos MCO

```{r modelo1}
# ===========================================================================
# MODELO 1: Lineal
# Y = β0 + β1·dem + β2·ln_gdp + u
# ===========================================================================

mod1 <- lm(te_cit_gdp ~ v2x_polyarchy + ln_gdp, data = df)
summary(mod1)
```

```{r modelo2}
# ===========================================================================
# MODELO 2: Log-lineal (variable dependiente en logaritmo)
# ln(Y) = β0 + β1·dem + β2·ln_gdp + u
# Interpretación: β1 × 100 = % de cambio en TE_CIT ante +1 unidad de democracia
# ===========================================================================

mod2 <- lm(ln_te_cit ~ v2x_polyarchy + ln_gdp, data = df)
summary(mod2)
```

```{r modelo3}
# ===========================================================================
# MODELO 3: Polinómico (cuadrático en democracia)
# Y = β0 + β1·dem + β2·dem² + β3·ln_gdp + u
# Permite captar una relación en forma de U o U invertida
# ===========================================================================

mod3 <- lm(te_cit_gdp ~ v2x_polyarchy + dem2 + ln_gdp, data = df)
summary(mod3)
```

```{r tabla_comparativa}
# 1. Creamos una copia temporal de los datos para la tabla
df_tab <- df

# 2. Renombramos las variables para que tengan nombres presentables
df_tab$Democracia      <- df_tab$v2x_polyarchy
df_tab$Democracia_cuad <- df_tab$dem2
df_tab$ln_PIB          <- df_tab$ln_gdp

df_tab$Gasto_CIT       <- df_tab$te_cit_gdp
df_tab$ln_Gasto_CIT    <- df_tab$ln_te_cit

# 3. Re-estimamos los modelos (los resultados matemáticos son idénticos)
m1 <- lm(Gasto_CIT ~ Democracia + ln_PIB, data = df_tab)
m2 <- lm(ln_Gasto_CIT ~ Democracia + ln_PIB, data = df_tab)
m3 <- lm(Gasto_CIT ~ Democracia + Democracia_cuad + ln_PIB, data = df_tab)

# 4. Imprimimos la tabla. 
# CLAVE: Pasamos los modelos en orden (m1, m3, m2) para que stargazer agrupe 
# los dos modelos de "Gasto_CIT" juntos y no colapse.
stargazer(m1, m3, m2,
          type = "text",
          title = "Comparación de Modelos — Gasto en CIT",
          
          # Indicamos qué modelo es cuál según el nuevo orden (1, 3, 2)
          column.labels = c("Lineal", "Cuadrático", "Log-lineal"),
          
          digits = 4,
          star.cutoffs = c(0.1, 0.05, 0.01))
```

